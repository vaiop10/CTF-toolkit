# Configuration

 export SCRIPT_VERSION="1.0"
 export SCRIPT_NAME="CTF-utility-toolkit"
 export AUTHOR="Wein Vade"
 export LICENSE="MIT"
 export BUILD="20260711"


# colors

       RED='\033[0;31m'
       PURPLE='\033[0;35m'
       GREEN='\033[0;32m'
       NC='\033[0m' # No color output



# Functions definitions
print_head() {

clear
printf "    ${RED}\n"
printf "====================================\n"
printf "  ${NC}  $SCRIPT_NAME v$SCRIPT_VERSION${NC}\n"
printf "  ${NC}  LICENSE:$LICENSE     BUILD:$BUILD ${NC} \n"
printf "  ${PURPLE}[*] Check: help_page${NC}\n"
printf "${RED}====================================\n"
printf "    ${NC}\n"

}


base_64() {


local DATA="$1"
[[ -z $DATA ]] && { printf "${PURPLE}Usage: base_64 <string>${NC}\n"; return; }
local ENCODE=$( printf "$DATA\n" | base64 2> /dev/null )
local DECODE=$( printf "$DATA\n" | base64 -d 2> /dev/null )


[[ "$DATA" =~ ^([A-Za-z0-9+/]{4})*([A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$ ]] && { printf "${GREEN}$DECODE${NC}\n"; return; }
printf "${GREEN}[*] $DATA=$ENCODE${NC}\n"; return

}


url_enc() {

command -v jq >/dev/null || { printf "${PURPLE}[!] jq command not found.${NC}\n"; return 1; }

local DATA="$1"
[[ -z $DATA ]] && { printf "${GREEN}Usage: url_enc <data>${NC}\n"; return 2; }
local ENCODE=$( printf "$DATA\n" | jq -sRr @uri )

# [[ "$DATA" =~ %([^0-9A-Fa-f]|$)|%[0-9A-Fa-f]?$ ]]

printf "${GREEN}[*] $DATA=$ENCODE${NC}\n"; return

}

rot_13() {

local DATA="$1"
[[ -z $DATA ]] && { printf "${PURPLE}Usage: rot_13 <data>${NC}\n"; return 2; }

local ROT=$( echo "$DATA" | tr 'A-Za-z' 'N-ZA-Mn-za-m' )
printf "${GREEN}[*] $DATA=$ROT${NC}\n"; return

}

xor_helper() {

local DATA1="$1"
local DATA2="$2"

[[ -z $DATA1 || -z $DATA2 ]] && { printf "${PURPLE}Usage: xor_helper <number> <number>${NC}\n"; return 2; }

OUTPUT=$(($DATA1 ^ $DATA2))
printf "${PURPLE}[*] $OUTPUT${NC}\n"; return

}

hash_id() {


# \\- Hash identifier, supports only: -//#
# MD5, SHA1, SHA224, SHA256, SHA384, SHA512,
# CRC32, NTLM, RipeMD-160, SHA3-256, Whirlpool,
# bcrypt.

local HASH="$1"
[[ -z "$HASH" ]] && { printf "${PURPLE}Usage: hash_id <hash>${NC}\n"; return 2; }
local length="${#HASH}"


if [[ "$HASH" =~  ^[0-9a-fA-F]+$ ]]; then

   [[ $length -eq 8  ]] && printf "${GREEN} [ $hash ] hash type: CRC32${NC}\n"
   [[ $length -eq 32 ]] && printf "${GREEN} [ $hash ] hash type: MD5 or NTLM${NC}\n"
   [[ $length -eq 40 ]] && printf "${GREEN} [ $hash ] hash type: SHA1 or RipeMD-160${NC}\n"
   [[ $length -eq 56 ]] && printf "${GREEN} [ $hash ] hash type: SHA224${NC}\n"
   [[ $length -eq 60 ]] && printf "${GREEN} [ $hash ] hash type: bcrypt${NC}\n"
   [[ $length -eq 64 ]] && printf "${GREEN} [ $hash ] hash type: SHA256 or SHA3-256${NC}\n"
   [[ $length -eq 96 ]] && printf "${GREEN} [ $hash ] hash type: SHA384${NC}\n"
   [[ $length -eq 128 ]] && printf "${GREEN} [ $hash ] hash type: SHA512 or Whirlpool$NC}\n"
   [[ $length -gt 128 ]] && printf "${PURPLE}[*] Unknown hash type..${NC}"
else
     printf "${PURPLE}[!] error: not a valid hexadecimal string\n${NC}"
fi

}


hex_conversion() {

local DATA="$1"
[[ -z $DATA ]] && { printf "${PURPLE}Usage: hex_conversion <data>${NC}\n"; return 2; }
[[ "$DATA" =~ ^([0-9a-fA-F]{2})+$ ]] || { printf "${PURPLE}[!] invalid hex${NC}\n"; return 1; }

local OUTPUT=$( echo "$DATA" | xxd -r -p )
printf "${GREEN}[*] $DATA=$OUTPUT${NC}\n"; return

}


binary_conversion() {

local DATA="$1"
[[ -z $DATA ]] && { printf "${PURPLE}Usage: binary_conversion <data>${NC}\n"; return 2; }
[[ $DATA =~ ^[01]+$ ]] || { printf "${PURPLE}[!] Not valid binary.${NC}\n"; return 2; }

local OUTPUT=$( echo "$DATA" | perl -lpe '$_=pack"B*",$_' )
printf "${GREEN}[*] $DATA=$OUTPUT${NC}\n"; return

}



http_headers() {

local WEB="$1"

[[ -z $WEB ]] && { printf "${PURPLE}Usage: http_headers <website>${NC}\n"; return 2; }


exec 3<>"/dev/tcp/$WEB/80"

printf 'HEAD / HTTP/1.1\r\nHost: %s\r\nConnection: close\r\n\r\n' "$WEB" >&3

while IFS= read -r line <&3; do
   [[ -z "$line" ]] && break
   printf '%s\n' "$line:"
done

exec 3>&-
exec 3<&-

}


tcp_scan() {


TARGET="$1"
START_PORT="$2"
END_PORT="$3"


if [[ -z $TARGET || -z $START_PORT || -z $END_PORT ]]; then
 printf "${PURPLE}Usage: tcp_scan <host> <start_port> <end_port>${NC}\n"
  return 2
fi

for ((port=START_PORT; port<=END_PORT; port++)); do
   (
       exec 3<>/dev/tcp/$TARGET/$port
      if [[ $? -eq 0 ]]; then
       printf "${GREEN}[*] PORT $port: OPEN${NC}\n"
       exec 3<&-
       exec 3>&-
      fi
    ) 2>/dev/null &

     void 100
done

wait

}

